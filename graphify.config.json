{
  "include": [
    "app",
    "components",
    "lib",
    "hooks",
    "types",
    "content",
    "docs",
    "public",
    "data"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "build",
    "coverage",
    ".graphify",
    "graphify-out",
    "docs/graphify"
  ],
  "options": {
    "project_type": "nextjs",
    "language": "typescript",
    "css_framework": "tailwind",
    "seo_architecture": true,
    "analyze_schema": true,
    "analyze_content": true
  }
}
